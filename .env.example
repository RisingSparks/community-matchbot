# LLM Provider
LLM_PROVIDER=openai                    # anthropic | openai
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-haiku-4-5
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-5-nano
OPENAI_SERVICE_TIER=flex

# LLM thresholds
LLM_EXTRACTION_CONFIDENCE_THRESHOLD=0.7

# Matching thresholds
MATCHING_MIN_SCORE=0.3
MATCHING_LLM_TRIAGE_BAND_LOW=0.3
MATCHING_LLM_TRIAGE_BAND_HIGH=0.55

# Reddit
REDDIT_ENABLED=false
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=matchbot/0.1 by u/your-reddit-username
REDDIT_USERNAME=your-reddit-username
REDDIT_PASSWORD=your-reddit-password
REDDIT_JSON_ENABLED=true
REDDIT_JSON_POLL_INTERVAL_SECONDS=300
REDDIT_JSON_FETCH_LIMIT=100
REDDIT_JSON_USER_AGENT=matchbot/0.1 by u/your-reddit-username (json-poller)

# Discord
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_MODERATOR_CHANNEL_ID=

# Facebook
FACEBOOK_ENABLED=false
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_PAGE_ACCESS_TOKEN=your-page-access-token
FACEBOOK_VERIFY_TOKEN=choose-a-random-string

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
VERBOSE=false

# Storage
DATABASE_BACKEND=sqlite
DB_PATH=matchbot.db
REPORT_OUTPUT_DIR=./reports
NEON_DATABASE_URL=

# Moderator
MODERATOR_NAME=Matchbot Moderator
MOD_PASSWORD=your-password-here
MOD_SECRET_KEY=a-long-random-string-here
